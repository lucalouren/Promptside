{
  "name": "promptdiff",
  "version": "0.1.0-alpha.0",
  "description": "Run the same prompt across multiple LLMs and diff the results, side-by-side.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "promptdiff": "./bin/promptdiff.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bin/promptdiff.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "prompt",
    "diff",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "evaluation",
    "cli"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
