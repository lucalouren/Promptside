{
  "name": "promptside",
  "version": "0.1.1",
  "description": "Run the same prompt across LLMs and see a side-by-side diff with tokens, latency, and cost",
  "license": "MIT",
  "author": "lucalouren",
  "type": "module",
  "bin": {
    "promptside": "bin/promptside.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bin/promptside.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucalouren/promptside.git"
  },
  "bugs": {
    "url": "https://github.com/lucalouren/promptside/issues"
  },
  "homepage": "https://github.com/lucalouren/promptside#readme",
  "keywords": [
    "llm",
    "ai",
    "prompt",
    "claude",
    "gpt",
    "gemini",
    "diff",
    "compare",
    "cli",
    "anthropic",
    "openai",
    "google"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@google/genai": "^1.52.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "openai": "^6.36.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
